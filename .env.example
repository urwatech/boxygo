APP_NAME=BoxyGo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=boxygo
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail is sent through SendGrid in production; "log" writes emails to the
# laravel.log instead, which is easiest for local development.
MAIL_MAILER=log
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# --- Transactional email templates (SendGrid dynamic templates) ---
SENDGRID_API_KEY=
SENDGRID_VERIFICATION_TEMPLATE_ID=
SENDGRID_PASSWORD_RESET_TEMPLATE_ID=
SENDGRID_EMPLOYEE_INVITATION_TEMPLATE_ID=
SENDGRID_WELCOME_USER_TEMPLATE_ID=
SENDGRID_SHIPMENT_VERIFICATION_TEMPLATE_ID=

# --- Maps & geocoding ---
# Map & location provider: 'openstreetmap' (no key required) or 'google'
MAP_PROVIDER=openstreetmap
LOCATION_AUTOCOMPLETE_PROVIDER=openstreetmap
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
# Use direct Google Geocoding API from frontend (true) or backend proxy (false).
# Direct API may encounter CORS issues; backend proxy is recommended.
USE_DIRECT_GOOGLE_API=false

# --- Firebase (web push notifications) ---
# Values from your Firebase project settings. Also place the service-account
# JSON at storage/app/firebase-credentials.json (never commit it).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# --- SMS gateway (MTN) ---
MTN_SMS_BASE_URL=
MTN_SMS_SECRET=
MTN_SMS_EMAIL=
MTN_SMS_PASSWORD=

# --- Payment gateway (shared by the MTN / Syriatel / Paymera services) ---
MTN_PAYMENT_BASE_URL=
MTN_PAYMENT_SECRET=
MTN_PAYMENT_EMAIL=
MTN_PAYMENT_PASSWORD=

# --- Assatex CRM integration (optional) ---
ASSATEX_API_URL=
ASSATEX_API_KEY=

# --- Pricing ---
PRICING_PLATFORM_FEE=0
PRICING_VAT_RATE=0
